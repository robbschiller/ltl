// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  picks Pick[]
  score UserScore?
}

model Pick {
  id            String   @id @default(cuid())
  userId        String
  gameId        String // External game ID from sports API
  playerId      String // Can be player ID or 'team'
  playerPosition String? // Optional position if player
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId]) // One pick per user per game
  @@index([userId])
  @@index([gameId])
}

model Game {
  id               String   @id
  nhlGameId        Int?
  opponent         String
  opponentLogo     String
  date             String
  time             String
  venue            String
  isHome           Boolean
  startTimeUTC     String?
  status           String
  teamGoals        Int      @default(0)
  opponentGoals    Int      @default(0)
  wentToOT         Boolean  @default(false)
  emptyNetGoals    Int      @default(0)
  shootoutOccurred Boolean  @default(false)
  lockedAt         DateTime?
  finalizedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([finalizedAt])
}

model GameUserScore {
  id        String   @id @default(cuid())
  gameId    String
  userId    String
  points    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gameId, userId])
  @@index([gameId])
  @@index([userId])
}

model UserScore {
  id                String   @id @default(cuid())
  userId            String   @unique
  totalSeasonPoints Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PickOrder {
  id        String   @id @default(cuid())
  userIds   String   // JSON array of user IDs in order
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([id]) // Only one pick order record
}
